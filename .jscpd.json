{
  "path": ["src", "scripts"],
  "reporters": ["console", "json", "threshold"],
  "output": "reports/jscpd",
  "gitignore": true,
  "minLines": 5,
  "minTokens": 50,
  "threshold": 2,
  "ignore": [
    "**/node_modules/**",
    "**/.git/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/reports/**",
    "**/vendor/**",
    "**/*.min.*",
    "**/*.lock",
    "**/fixtures/**",
    "**/__fixtures__/**",
    "**/__snapshots__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
